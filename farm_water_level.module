<?php

/**
 * @file
 * Contains farm_water_level.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function farm_water_level_help($route_name, RouteMatchInterface $route_match) {
  $output = '';
  switch ($route_name) {
    case 'help.page.farm_water_level':
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Pulls water level sensor data from ThingSpeak and displays it in farmOS. Readings are synced periodically and stored as water level logs.') . '</p>';
      $output .= '<h3>' . t('Configuration') . '</h3>';
      $output .= '<p>' . t('Go to <a href=":url">Water Level Sensor Settings</a> to configure your ThingSpeak channel ID and Read API key.', [':url' => '/admin/config/farm/water-level']) . '</p>';
      break;
  }
  return $output;
}

/**
 * Implements hook_cron().
 *
 * Fetches new water level readings from ThingSpeak and creates log entities.
 */
function farm_water_level_cron() {
  $config = \Drupal::config('farm_water_level.settings');
  $interval = $config->get('sync_interval') ?: 3600;
  $state = \Drupal::state();
  $last_run = $state->get('farm_water_level.last_sync', 0);
  $now = \Drupal::time()->getRequestTime();

  if (($now - $last_run) < $interval) {
    return;
  }

  /** @var \Drupal\farm_water_level\ThingSpeakClient $client */
  $client = \Drupal::service('farm_water_level.thingspeak_client');
  $entries = $client->fetchFeed();

  if (empty($entries)) {
    $state->set('farm_water_level.last_sync', $now);
    return;
  }

  $last_entry_id = (int) $state->get('farm_water_level.last_entry_id', 0);
  $new_entries = array_filter($entries, function ($entry) use ($last_entry_id) {
    return !empty($entry['entry_id']) && $entry['entry_id'] > $last_entry_id;
  });

  if (empty($new_entries)) {
    $state->set('farm_water_level.last_sync', $now);
    return;
  }

  $log_storage = \Drupal::entityTypeManager()->getStorage('log');
  $max_entry_id = $last_entry_id;

  foreach ($new_entries as $entry) {
    $timestamp = strtotime($entry['created_at']);
    if ($timestamp === FALSE) {
      continue;
    }

    $log = $log_storage->create([
      'type' => 'water_level',
      'name' => t('Water level reading @time', [
        '@time' => \Drupal::service('date.formatter')->format($timestamp, 'short'),
      ]),
      'timestamp' => $timestamp,
      'status' => 'done',
      'notes' => [
        'value' => t('Auto-synced from ThingSpeak. Entry ID: @id, Value: @val', [
          '@id' => $entry['entry_id'],
          '@val' => $entry['value'],
        ]),
        'format' => 'default',
      ],
    ]);

    $quantity_storage = \Drupal::entityTypeManager()->getStorage('quantity');
    $quantity = $quantity_storage->create([
      'type' => 'standard',
      'measure' => 'length',
      'value' => [
        'numerator' => (int) ($entry['value'] * 1000),
        'denominator' => 1000,
      ],
      'units' => 'cm',
      'label' => t('Water level'),
    ]);
    $quantity->save();

    $log->set('quantity', [$quantity]);
    $log->save();

    if ($entry['entry_id'] > $max_entry_id) {
      $max_entry_id = $entry['entry_id'];
    }
  }

  $state->set('farm_water_level.last_entry_id', $max_entry_id);
  $state->set('farm_water_level.last_sync', $now);

  \Drupal::logger('farm_water_level')->info('Synced @count new water level readings from ThingSpeak.', [
    '@count' => count($new_entries),
  ]);
}

/**
 * Implements hook_farm_entity_bundle_field_info().
 */
function farm_water_level_farm_entity_bundle_field_info() {
  $fields = [];

  $fields['log']['water_level']['sensor_depth'] = [
    'type' => 'fraction',
    'label' => t('Sensor depth'),
    'description' => t('The installation depth of the water level sensor.'),
    'weight' => [
      'form' => 15,
      'view' => 15,
    ],
  ];

  return $fields;
}
